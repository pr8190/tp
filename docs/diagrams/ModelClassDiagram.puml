@startuml
!include style.puml
skinparam arrowThickness 1.1
skinparam arrowColor MODEL_COLOR
skinparam classBackgroundColor MODEL_COLOR
skinparam linetype polyline

Package Model as ModelPackage <<Rectangle>>{
Class "<<interface>>\nReadOnlyAddressBook" as ReadOnlyAddressBook
Class "<<interface>>\nReadOnlyUserPrefs" as ReadOnlyUserPrefs
Class "<<interface>>\nModel" as Model
Class "<<enumeration>>\nTagType" as TagType
Class AddressBook
Class ModelManager
Class UserPrefs

Class UniquePersonList
Class Person
Class Email
Class EmergencyContact
Class Name
Class Phone
Class Remark
Class RoomNumber
Class StudentId
Class Tag
Class Remark
Class DemeritIncident

Class I #FFFFFF
}

Class HiddenOutside #FFFFFF
HiddenOutside ..> Model

AddressBook .up.|> ReadOnlyAddressBook

ModelManager .up.|> Model
Model .right.> ReadOnlyUserPrefs
Model .left.> ReadOnlyAddressBook
ModelManager -left-> "1" AddressBook
ModelManager -right-> "1" UserPrefs
UserPrefs .up.|> ReadOnlyUserPrefs

AddressBook *--> "1" UniquePersonList
UniquePersonList --> "~* all" Person
Person *--> "1" Name
Person *--> "1" StudentId
Person *--> "1" Phone
Person *--> "1" Email
Person *--> "1" RoomNumber
Person *--> "1" EmergencyContact
Person *--> "0..1" Remark
Person *--> "0..3" Tag
Person *--> "*" DemeritIncident
Tag --> "1" TagType

Person -[hidden]up--> I
UniquePersonList -[hidden]right-> I

Name -[hidden]right-> StudentId
StudentId -[hidden]right-> Phone
Phone -[hidden]right-> Email
Email -[hidden]right-> RoomNumber
RoomNumber -[hidden]right-> EmergencyContact

EmergencyContact -[hidden]down-> Remark
Remark -[hidden]right-> Tag
Tag -[hidden]right-> DemeritIncident

ModelManager --> "~* filtered\n\n" Person
@enduml
