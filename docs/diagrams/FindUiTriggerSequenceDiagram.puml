@startuml
!include style.puml

'' Make the text not bold
skinparam DefaultFontStyle plain
skinparam SequenceParticipantFontStyle plain
skinparam SequenceMessageFontStyle plain
skinparam SequenceGroupFontStyle plain

actor User

box "UI" UI_COLOR_T1
participant ":FilterPanel" as FilterPanel UI_COLOR
participant ":MainWindow" as MainWindow UI_COLOR
end box

box "Logic" LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant "f:FindCommand" as FindCommand LOGIC_COLOR
end box

box "Model" MODEL_COLOR_T1
participant "m:Model" as Model MODEL_COLOR
end box

User -> FilterPanel : types keyword + presses Enter
activate FilterPanel

FilterPanel -> FilterPanel : updateFilterDetails(...)
FilterPanel -> MainWindow : executeFilter(filterDetails)
activate MainWindow

MainWindow -> LogicManager : executeFilter(filterDetails)
activate LogicManager
LogicManager -> FindCommand : create(filterDetails)
activate FindCommand
FindCommand -> Model : updateFilteredPersonList(predicate)
activate Model
Model --> FindCommand :

deactivate Model
FindCommand --> LogicManager : CommandResult

deactivate FindCommand
LogicManager --> MainWindow : CommandResult

deactivate LogicManager
MainWindow --> FilterPanel : refresh UI + feedback

deactivate MainWindow
deactivate FilterPanel
@enduml

