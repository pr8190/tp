<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane fx:id="placeHolder" styleClass="pane-without-border" stylesheets="@DarkTheme.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
   <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" prefHeight="200.0" styleClass="undecorated-scroll-pane">
      <content>
         <TextArea fx:id="resultDisplay" editable="false" promptText="View your command result here" styleClass="result-display" wrapText="true" />
      </content>
   </ScrollPane>
</StackPane>
