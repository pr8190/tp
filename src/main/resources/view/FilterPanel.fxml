<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>

<TitledPane animated="true" expanded="false" minWidth="320.0" styleClass="filter-pane" stylesheets="@DarkTheme.css" text="Filter" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
    <graphic>
        <FontIcon iconLiteral="dashicons-filter" iconSize="16" styleClass="filter-icon" />
    </graphic>
    <content>
        <ScrollPane fitToWidth="true" styleClass="edge-to-edge">
            <VBox minHeight="0.0" spacing="15.0" styleClass="pane-without-border">
                <padding>
                    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                </padding>

                <StackPane fx:id="nameFilterFieldPlaceholder" />

                <GridPane hgap="20.0" vgap="15.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="50.0" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="50.0" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints vgrow="SOMETIMES" />
                        <RowConstraints vgrow="SOMETIMES" />
                        <RowConstraints vgrow="SOMETIMES" />
                    </rowConstraints>

                    <StackPane fx:id="phoneFilterFieldPlaceholder" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <StackPane fx:id="emailFilterFieldPlaceholder" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                    <StackPane fx:id="studentIdFilterFieldPlaceholder" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                    <StackPane fx:id="roomNumberFilterFieldPlaceholder" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                    <StackPane fx:id="majorFilterFieldPlaceholder" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                    <StackPane fx:id="emergencyContactFilterFieldPlaceholder" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                </GridPane>

                <GridPane hgap="20.0" vgap="15.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" percentWidth="50.0" />
                        <ColumnConstraints hgrow="SOMETIMES" percentWidth="50.0" />
                    </columnConstraints>
                    <children>
                        <StackPane fx:id="yearFilterFieldPlaceholder" GridPane.columnIndex="0" />
                        <StackPane fx:id="genderFilterFieldPlaceholder" GridPane.columnIndex="1" />
                    </children>
                    <rowConstraints>
                        <RowConstraints />
                    </rowConstraints>
                </GridPane>
            </VBox>
        </ScrollPane>
    </content>
</TitledPane>
