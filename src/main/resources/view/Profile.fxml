<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" styleClass="panel-container" stylesheets="@DarkTheme.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
    <TextField fx:id="nameField" editable="false" focusTraversable="false" styleClass="panel-heading" />

    <FlowPane fx:id="tags">
        <VBox.margin>
            <Insets bottom="2.0" />
        </VBox.margin>
    </FlowPane>

    <GridPane hgap="10" vgap="15" VBox.vgrow="ALWAYS">
        <columnConstraints>
            <ColumnConstraints hgrow="ALWAYS" maxWidth="296.0" minWidth="134.0" prefWidth="150.0" />
            <ColumnConstraints hgrow="ALWAYS" maxWidth="348.0" minWidth="94.0" prefWidth="256.0" />
        </columnConstraints>

        <Label styleClass="label-bright" text="Student Id:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <TextField fx:id="studentIdField" editable="false" focusTraversable="false" styleClass="label-field" GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <Label styleClass="label-bright" text="Room:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <TextField fx:id="roomField" editable="false" focusTraversable="false" styleClass="label-field" GridPane.columnIndex="1" GridPane.rowIndex="1" />

        <Label styleClass="label-bright" text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <TextField fx:id="emailField" editable="false" focusTraversable="false" styleClass="label-field" GridPane.columnIndex="1" GridPane.rowIndex="2" />

        <Label styleClass="label-bright" text="Emergency Contact:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
        <TextField fx:id="emergencyContactField" editable="false" focusTraversable="false" styleClass="label-field" GridPane.columnIndex="1" GridPane.rowIndex="3" />

        <Label styleClass="label-bright" text="Remark" GridPane.columnIndex="0" GridPane.rowIndex="5" />
        <TextField fx:id="remarkField" editable="false" focusTraversable="false" styleClass="label-remark" GridPane.columnSpan="2" GridPane.rowIndex="6" />
        <rowConstraints>
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
         <RowConstraints />
        </rowConstraints>
    </GridPane>
</VBox>
